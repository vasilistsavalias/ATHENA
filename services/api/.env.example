APP_ENV=development
APP_INVITE_CODE=athena-invite
APP_SHARED_USERNAME=archaeologist
APP_SHARED_PASSWORD=change-me
SESSION_SECRET=change-me-session-secret
ADMIN_EXPORT_SECRET=change-me-admin-secret
ADMIN_UI_PASSWORD=change-me-admin-ui-password
ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite:///./data/website.db
BLOCK_A_TARGET_COUNT=25
BLOCK_B_TARGET_COUNT=15
BLOCK_A_ATTENTION_CHECKS=2
BLOCK_B_ATTENTION_CHECKS=1

# Optional: bootstrap a campaign from a zip at startup (useful on ephemeral disks)
# BOOTSTRAP_PACK_ON_STARTUP=true
# BOOTSTRAP_PACK_ZIP_PATH=/opt/render/project/src/website/services/api/bootstrap/final_expert_pack.zip
# BOOTSTRAP_CAMPAIGN_NAME=ATHENA Final V8 Expert Validation
# BOOTSTRAP_CAMPAIGN_SEED=2026
# BOOTSTRAP_ACTIVATE=true
# BOOTSTRAP_DISJOINT_BLOCKS=true
# BOOTSTRAP_STRICT=false

# Cross-origin cookie settings (required for Vercel+Render production)
# SESSION_COOKIE_SAMESITE=none   # use "none" for cross-origin (Vercel<->Render)
# SESSION_COOKIE_SECURE=true     # must be true when samesite=none
# SESSION_COOKIE_DOMAIN=          # leave blank unless you use a custom domain
